APP_ENV=local
RUN_MODE=standalone
SERVICE_NAME=ai-invoice-verification-agent
LOG_LEVEL=DEBUG

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vision_ai
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
ENABLE_DATABASE=false
ENABLE_RABBITMQ=false

YOLO_MODEL_PATH=./models/yolo11s-elvis.pt
YOLO_INPUT_SIZE=640
YOLO_CONFIDENCE_THRESHOLD=0.40
YOLO_NMS_THRESHOLD=0.45

OCR_PROVIDER=paddleocr_vl
OCR_ENABLE_PDF_TEXT_EXTRACTION=true
OCR_USE_GPU=true
PADDLEOCR_VL_MODEL_DIR=/mnt/models/PaddleOCR-VL-1.6

# Use this when OCR_PROVIDER=qwen or when Qwen reasoning is enabled.
VLM_MODEL_PATH=/mnt/models/Qwen2.5-VL-7B-Instruct-AWQ
VLM_MAX_TOKENS=2048
ENABLE_QWEN_REASONING=false
QWEN_REASONING_MODEL_PATH=/mnt/models/Qwen2.5-VL-7B-Instruct-AWQ
QWEN_REASONING_MAX_TOKENS=1024

MAX_FILE_SIZE_MB=25
MAX_PAGE_COUNT=5
CONFIDENCE_THRESHOLD=80

INTERNAL_API_KEY=dev-api-key-change-me
