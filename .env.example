# Vision AI environment template
#
# DGX Spark testing:
#   cp .env.example .env
#   docker compose --profile standalone up -d --build --force-recreate
#
# Production:
#   Keep RabbitMQ and database enabled, then run the prod worker profile.
#   Do not use production mode for Streamlit upload testing.

# -----------------------------------------------------------------------------
# Active default: DGX Spark standalone testing via Streamlit upload
# -----------------------------------------------------------------------------
APP_ENV=local
RUN_MODE=standalone
SERVICE_NAME=ai-invoice-verification-agent
LOG_LEVEL=DEBUG

ENABLE_DATABASE=false
ENABLE_RABBITMQ=false

# These URLs are kept for compatibility with code paths and production override.
# They are not used when ENABLE_DATABASE=false and ENABLE_RABBITMQ=false.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vision_ai
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# -----------------------------------------------------------------------------
# Models
# -----------------------------------------------------------------------------
YOLO_MODEL_PATH=./models/best-v5.pt
YOLO_INPUT_SIZE=640
YOLO_CONFIDENCE_THRESHOLD=0.40
YOLO_NMS_THRESHOLD=0.45
YOLO_HIGH_RES_INPUT_SIZE=960
YOLO_BATCH_SIZE=2

# Streamlit and the production worker call one shared Paddle model service.
OCR_PROVIDER=paddleocr_vl
OCR_ENABLE_PDF_TEXT_EXTRACTION=true

# Qwen2.5-VL OCR / reasoning.
VLM_MODEL_PATH=/mnt/models/Qwen2.5-VL-7B-Instruct-AWQ
VLM_MAX_TOKENS=2048
VLM_GPU_MEMORY_UTILIZATION=0.20
QWEN_SERVICE_URL=
QWEN_MAX_MODEL_LEN=4096
QWEN_MAX_NUM_SEQS=1
MAX_PARALLEL_DOCUMENTS=1
MAX_PARALLEL_PAGES=1
PAGE_MICRO_BATCH_SIZE=2
MAX_INFLIGHT_PAGES=2
PDF_DEFAULT_DPI=200
PDF_FALLBACK_DPI=260

# PaddleOCR-VL 1.6 POC defaults.
PADDLEOCR_VL_MODEL_DIR=/mnt/models/PaddleOCR-VL-1.6
PADDLEOCR_VL_SERVICE_URL=
PADDLEOCR_VL_PIPELINE_VERSION=v1.6
PADDLEOCR_VL_ENGINE=transformers
PADDLEOCR_VL_DEVICE=gpu
PADDLEOCR_VL_USE_LAYOUT_DETECTION=true
PADDLEOCR_VL_FORMAT_BLOCK_CONTENT=true
PADDLEOCR_VL_USE_QUEUES=true

# Optional reasoning pass after OCR/YOLO. Keep disabled for first testing.
ENABLE_QWEN_REASONING=false

# -----------------------------------------------------------------------------
# Limits and validation
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=25
MAX_PAGE_COUNT=50
CONFIDENCE_THRESHOLD=85

# -----------------------------------------------------------------------------
# API auth
# -----------------------------------------------------------------------------
INTERNAL_API_KEY=dev-api-key-change-me

# -----------------------------------------------------------------------------
# Production override reference
# -----------------------------------------------------------------------------
# To switch this same file to production, change the active values above to:
#
# APP_ENV=production
# RUN_MODE=worker
# LOG_LEVEL=INFO
# ENABLE_DATABASE=true
# ENABLE_RABBITMQ=true
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/vision_ai
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
#
# Then run:
#   docker compose --profile prod up -d --build postgres rabbitmq ai-worker
#
